# Internal-only notes (kept locally for the team; not part of the public release).
INTERNAL.md

# Heavy artifacts — downloaded or trained; always out of source control.
# Note: no trailing slash, so symlinks named `pretrained` are caught too.
/pretrained
/work_dirs

# Eval outputs — regenerated by running the test sweeps.
playground/coco/*
!playground/coco/.gitkeep

# Python caches and build artifacts.
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/

# Editor / OS junk.
.vscode/
.idea/
.DS_Store
*.swp
*.swo
